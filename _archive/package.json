{
    "name": "atrosha-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run dev:landing\" \"npm run dev:dashboard\"",
        "dev:landing": "cd landing-page && npm run dev",
        "dev:dashboard": "cd Atrosha/dashboard && npm run dev",
        "build": "concurrently \"npm run build:landing\" \"npm run build:dashboard\"",
        "build:landing": "cd landing-page && npm run build",
        "build:dashboard": "cd Atrosha/dashboard && npm run build"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}