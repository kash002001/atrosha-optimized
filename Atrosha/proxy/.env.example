# ------------------------------------------------------------------------------
# ATROSHA PROXY: ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# [MANDATORY] Cryptographic secrets — generate with: openssl rand -hex 32
PERMIT_SECRET=
ADMIN_SECRET=

# [INFRASTRUCTURE]
REDIS_URL=redis://localhost:6379/
CLICKHOUSE_URL=http://localhost:8123/
SEMANTIC_ENGINE_URL=http://localhost:8002

# [CLICKHOUSE AUTH] (optional — needed if ClickHouse requires authentication)
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# [LOGGING]
RUST_LOG=atrosha_proxy=debug
