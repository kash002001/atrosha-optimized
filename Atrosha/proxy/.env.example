# ------------------------------------------------------------------------------
# ATROSHA ENTERPRISE: PROXY ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# [MANDATORY] 
# The Permit Secret is used by the Intent Validator to sign cryptographic 
# permits. This MUST be a secure 32-byte randomized string in production.
# Example: openssl rand -hex 32
PERMIT_SECRET=super-secret-key-change-me-in-production

# [INFRASTRUCTURE]
# Connection strings for the high-speed caching and audit datastores.
REDIS_URL=redis://localhost:6379/
CLICKHOUSE_URL=http://localhost:8123/
SEMANTIC_ENGINE_URL=http://localhost:8002

# [LOGGING]
# Set to 'info' or 'error' in production to minimize I/O overhead.
RUST_LOG=atrosha_proxy=debug
