# ------------------------------------------------------------------------------
# ATROSHA PROXY: ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in all required values.
# NEVER commit the actual .env file to version control.
# ------------------------------------------------------------------------------

# [MANDATORY] Cryptographic secrets — generate with: openssl rand -hex 32
PERMIT_SECRET=
ADMIN_SECRET=

# [MANDATORY] ZKP proof enforcement
# Set to "true" in production to hard-block transactions when ZKP generation fails.
# Set to "false" only during development/debugging — transactions will pass even if proof fails.
REQUIRE_ZKP_PROOF=true

# [ZKP POLICY] Maximum transaction amount enforced by the ZKP circuit.
# Unit: CENTS. Default is 9999999 = $99,999.99 per transaction.
# Changing this requires a proxy redeploy (the circuit is recompiled at startup).
PROXY_ZKP_AMOUNT_LIMIT_CENTS=9999999

# [EVM ADAPTER — required if using EVM rail]
# WARNING: do NOT use a Hardhat/test private key in production. Generate a fresh key:
#   openssl rand -hex 32
# The proxy will refuse to start if ETH_PRIVATE_KEY is not set when the EVM adapter is active.
ETH_PRIVATE_KEY=
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
EVM_EXPLORER_URL=https://etherscan.io

# [INFRASTRUCTURE]
REDIS_URL=redis://localhost:6379/
CLICKHOUSE_URL=http://localhost:8123/
SEMANTIC_ENGINE_URL=http://localhost:8002

# [CLICKHOUSE AUTH] (optional — needed if ClickHouse requires authentication)
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# [LOGGING]
RUST_LOG=atrosha_proxy=info
