# ------------------------------------------------------------------------------
# ATROSHA ENTERPRISE: SOVEREIGN AGENT CONFIGURATION
# ------------------------------------------------------------------------------

# [MANDATORY]
# The API Key used by the agent SDK to authenticate against the Rust Proxy.
# This aligns with the $ATROSHA_API_KEY environment variable.
ATROSHA_API_KEY=your_issued_agent_api_key_here

# [NETWORK]
# The URL where the Atrosha Rust Proxy is listening.
# In a VPC, this should point to the internal load balancer.
PROXY_URL=http://127.0.0.1:8080

# [LOCAL STATE]
# The path where the SQLite audit trail for the agent is stored.
ATROSHA_DB_PATH=atrosha.db

# [API KEYS]
# OpenAI key required for the core semantic processing of the AI agent.
OPENAI_API_KEY=sk-...
