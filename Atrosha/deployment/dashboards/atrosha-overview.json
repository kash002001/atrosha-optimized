{
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "options": {
                "legend": {
                    "calcs": [
                        "mean",
                        "max"
                    ],
                    "displayMode": "table"
                }
            },
            "targets": [
                {
                    "expr": "rate(atrosha_proxy_req_duration_seconds_count[5m])",
                    "legendFormat": "{{method}} - {{status}}"
                }
            ],
            "title": "Request Rate",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "id": 2,
            "options": {
                "legend": {
                    "calcs": [
                        "mean",
                        "p95",
                        "max"
                    ],
                    "displayMode": "table"
                }
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(atrosha_proxy_req_duration_seconds_bucket[5m]))",
                    "legendFormat": "p95"
                },
                {
                    "expr": "histogram_quantile(0.50, rate(atrosha_proxy_req_duration_seconds_bucket[5m]))",
                    "legendFormat": "p50"
                }
            ],
            "title": "Request Latency",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 100
                            }
                        ]
                    },
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 8
            },
            "id": 3,
            "options": {
                "colorMode": "value",
                "graphMode": "area"
            },
            "targets": [
                {
                    "expr": "sum(increase(atrosha_denials_total[1h]))",
                    "legendFormat": "Total Denials"
                }
            ],
            "title": "Denials (Last Hour)",
            "type": "stat"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${datasource}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            },
            "gridPos": {
                "h": 8,
                "w": 16,
                "x": 8,
                "y": 8
            },
            "id": 4,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "sum by (reason) (increase(atrosha_denials_total[1h]))",
                    "legendFormat": "{{reason}}"
                }
            ],
            "title": "Denials by Reason",
            "type": "piechart"
        }
    ],
    "refresh": "30s",
    "schemaVersion": 38,
    "style": "dark",
    "tags": [
        "atrosha",
        "security"
    ],
    "templating": {
        "list": [
            {
                "current": {},
                "hide": 0,
                "includeAll": false,
                "label": "Datasource",
                "name": "datasource",
                "options": [],
                "query": "prometheus",
                "refresh": 1,
                "type": "datasource"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "",
    "title": "Atrosha Overview",
    "uid": "atrosha-overview",
    "version": 1
}